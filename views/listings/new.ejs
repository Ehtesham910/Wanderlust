<% layout("/layouts/boilerplate") %>
<body>
<div class="row">
    <div class="col-8 offset-2">
    <h3>Create a New Listing</h3>
    <br><br>
    <form method="POST" action="/listings">
    <div class="mb-3">
        <lable for="title" class="form-label">Title</lable>
        <input 
            name="listing.[title]"
            placeholder="Enter title" 
            type="text" 
            class="form-control"
        >    
    </div>

    <div class="mb-3">
        <lable for="description" class="form-label">Description</lable>
        <textarea 
            name="listing.[description]" 
            placeholder="Enter Description"
            type="text"
            class="form-control"
        ></textarea>
    </div>

    <div class="row">
        <div class="mb-3 col-md-4">
            <lable for="price" class="form-label">Price</lable>
            <input
                name="listing.[price]"
                placeholder="Enter price"
                type="number"
                class="form-control"
            >
        </div>

        <div class="mb-3 col-md-8">
            <lable for="country" class="form-label">Country</lable>
            <input
                name="listing.[country]"
                placeholder="Enter Country"
                type="text"
                class="form-control"
           >
        </div> 
    </div>

    <div class="mb-3">
        <lable for="location" class="form-label">Location</lable>
        <input
            name="listing.[location]"
             placeholder="Enter Location"
            type="text"
            class="form-control"
        >
    </div>

    <br><br>    
    <button class="btn btn-dark add-btn">Add</button>
    <br><br>
</form>
</div>
</div>

</body>